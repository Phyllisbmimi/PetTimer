{
  "name": "pet-timer",
  "version": "1.0.0",
  "description": "Pet care and pomodoro timer app with goal tracking and achievement calendar",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "docker:build": "docker build -t pettimer:latest .",
    "docker:run": "docker run -p 3000:3000 pettimer:latest",
    "docker:compose": "docker-compose up -d"
  },
  "dependencies": {
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@types/js-cookie": "^3.0.6",
    "bcryptjs": "^3.0.3",
    "i18next": "^25.8.14",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.5",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.1.0",
    "vite": "^4.4.0"
  }
}
